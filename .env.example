# Local Docker Compose settings for OpenPolitics Lens.
# These are development credentials only. Copy to `.env.local` before changing
# values. Runtime commands should pass `--env-file .env.local` explicitly.

COMPOSE_PROJECT_NAME=openpolitics-lens

# PostgreSQL: relational system of record.
POSTGRES_DB=openpolitics
POSTGRES_USER=openpolitics
POSTGRES_PASSWORD=openpolitics_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://openpolitics:openpolitics_dev_password@localhost:5432/openpolitics
DATABASE_INTERNAL_URL=postgresql://openpolitics:openpolitics_dev_password@postgres:5432/openpolitics

# S3-compatible object storage: immutable raw artifacts.
MINIO_ROOT_USER=openpolitics
MINIO_ROOT_PASSWORD=openpolitics_minio_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=openpolitics-raw
S3_REGION=ap-northeast-1
S3_ENDPOINT=http://localhost:9000
S3_INTERNAL_ENDPOINT=http://minio:9000
S3_FORCE_PATH_STYLE=true

# Neo4j: relationship graph projection.
NEO4J_AUTH=neo4j/openpolitics_neo4j_dev_password
NEO4J_URI=bolt://localhost:7687
NEO4J_INTERNAL_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=openpolitics_neo4j_dev_password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512m

# Meilisearch: search index.
MEILI_ENV=development
MEILI_MASTER_KEY=openpolitics_meili_dev_master_key
MEILI_PORT=7700
MEILI_HOST=http://localhost:7700
MEILI_INTERNAL_HOST=http://meilisearch:7700
